# ── IA ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...         # Requis — Claude Opus 4.7 + Vision
OPENAI_API_KEY=sk-...                # Requis — gpt-image-1
OPENAI_IMAGE_MODEL=gpt-image-1       # Optionnel — modèle image utilisé par Visual Director

# ── Meta Graph API ───────────────────────────────────────────────────────────
META_APP_ID=                         # Optionnel — exchange token long (60j)
META_APP_SECRET=                     # Optionnel

# ── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=file:./codexrs.db       # Dev local — LibSQL fichier
# DATABASE_URL=libsql://xxx.turso.io # Prod — remplacer par URL Turso
DATABASE_AUTH_TOKEN=                 # Requis si DATABASE_URL est une URL Turso

# ── Stockage fichiers ────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=               # Vercel Blob — activer dans le dashboard Vercel
                                     # Si absent : stockage local (dev uniquement)

# ── URL publique ─────────────────────────────────────────────────────────────
CODEXRS_PUBLIC_URL=https://codexrs.vercel.app
NEXT_PUBLIC_APP_URL=https://codexrs.vercel.app
# Utilisé en fallback si BLOB_READ_WRITE_TOKEN absent et images en /uploads/*.
# Avec Vercel Blob actif, les images ont déjà des URLs publiques — pas nécessaire.

# ── Auth locale / production ────────────────────────────────────────────────
CODEXRS_PASSWORD=                   # Active la protection par mot de passe si défini
MULTI_USER_MODE=false               # true = comptes équipe + sessions par utilisateur
NEXT_PUBLIC_MULTI_USER_MODE=false   # même valeur côté UI
CODEXRS_ADMIN_EMAIL=                # Optionnel — owner créé au premier démarrage multi-user
CODEXRS_INITIAL_OWNER_PASSWORD=     # Optionnel — sinon CODEXRS_PASSWORD est utilisé

# ── Chiffrement des tokens (Phase 3) ─────────────────────────────────────────
MAESTRO_ENCRYPTION_KEY=             # Chiffre les tokens Meta en base (AES-256-GCM)
                                    # Générer : openssl rand -base64 32
                                    # Sans clé : tokens stockés en clair (warning au log)

# ── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=                         # Requis en prod — protège les routes /api/cron/*
                                     # Vercel Cron l'envoie automatiquement si défini

# ── Vidéo IA ─────────────────────────────────────────────────────────────────
LUMA_API_KEY=                        # Optionnel — active Video Creator / Image-to-Reel

# ── Local IA ─────────────────────────────────────────────────────────────────
OLLAMA_HOST=                         # Optionnel — serveur Ollama local
